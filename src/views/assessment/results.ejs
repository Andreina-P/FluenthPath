<!--
  Assessment results page.
  WCAG 2.4.2: Title "Assessment Results — FluentPath".
  WCAG 1.4.1: Level shown with text, not just a colored badge.
  data-autofocus moves focus to the heading on load.
-->

<div class="card" style="width:100%; text-align:center;">

  <h1 tabindex="-1" data-autofocus style="margin-bottom:var(--fp-space-2);">
    Assessment Complete
  </h1>

  <% if (results) { %>
    <!-- Just completed — show detailed results -->
    <p style="color:var(--fp-text-2); margin-bottom:var(--fp-space-6);">
      You answered <%= results.correct %> out of <%= results.total %> questions correctly.
    </p>

    <div class="card" style="background:var(--fp-bg); margin-bottom:var(--fp-space-6); padding:var(--fp-space-6);">
      <p style="font-size:var(--fp-text-sm); color:var(--fp-text-2); margin-bottom:var(--fp-space-2);">
        Your assigned level
      </p>
      <p style="font-size:var(--fp-text-3xl); font-weight:700; color:var(--fp-primary); margin-bottom:var(--fp-space-1);">
        <%
          const levelNames = {
            beginner: 'Beginner',
            elementary: 'Elementary',
            conversational: 'Conversational',
          };
        %>
        <%= levelNames[results.level] || results.level %>
      </p>
      <p style="font-size:var(--fp-text-sm); color:var(--fp-text-2); margin:0;">
        Score: <%= results.score %>%
      </p>
    </div>

    <p style="color:var(--fp-text-2); font-size:var(--fp-text-sm); max-width:none;">
      <% if (results.level === 'beginner') { %>
        Start with the basics. We recommend beginning with Lesson 1.1: Intro to Greetings.
      <% } else if (results.level === 'elementary') { %>
        You have a solid foundation. We recommend starting with Lesson 2.1: Past Continuous.
      <% } else { %>
        You are doing great. We recommend jumping into advanced grammar topics.
      <% } %>
    </p>

  <% } else if (assessmentLevel) { %>
    <!-- Previously completed — show saved level -->
    <p style="color:var(--fp-text-2); margin-bottom:var(--fp-space-6);">
      You have already completed the level assessment.
    </p>

    <div class="card" style="background:var(--fp-bg); margin-bottom:var(--fp-space-6); padding:var(--fp-space-6);">
      <p style="font-size:var(--fp-text-sm); color:var(--fp-text-2); margin-bottom:var(--fp-space-2);">
        Your current level
      </p>
      <p style="font-size:var(--fp-text-3xl); font-weight:700; color:var(--fp-primary); margin:0;">
        <%
          const savedLevelNames = {
            beginner: 'Beginner',
            elementary: 'Elementary',
            conversational: 'Conversational',
          };
        %>
        <%= savedLevelNames[assessmentLevel] || assessmentLevel %>
      </p>
    </div>

  <% } else { %>
    <p style="color:var(--fp-text-2);">No assessment results found.</p>
  <% } %>

  <div style="display:flex; justify-content:center; gap:var(--fp-space-3); margin-top:var(--fp-space-6);">
    <a href="/lessons" class="btn btn-primary">Browse lessons</a>
    <a href="/dashboard" class="btn btn-secondary">Go to dashboard</a>
  </div>

</div>
