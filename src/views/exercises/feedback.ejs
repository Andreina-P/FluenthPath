<!--
  Exercise feedback — FULL PAGE, not a modal.
  WCAG 2.1.2: No focus trap.
  WCAG 2.4.2: Own <title>.
  WCAG 1.4.1: Correct/incorrect with icon + text, not color alone.
  Focus moves to h2 via data-autofocus (focus-manager.js).
-->

<div class="feedback <%= isCorrect ? 'feedback--correct' : 'feedback--error' %>"
     style="max-width:580px; margin:0 auto; padding:var(--fp-space-8) var(--fp-space-6);">

  <!-- Result icon — clean SVG -->
  <div style="text-align:center; margin-bottom:var(--fp-space-4);">
    <% if (isCorrect) { %>
      <svg aria-hidden="true" focusable="false" width="56" height="56" viewBox="0 0 56 56" fill="none" style="margin:0 auto;">
        <circle cx="28" cy="28" r="26" stroke="var(--fp-success)" stroke-width="3" fill="var(--fp-success-tint)"/>
        <path d="M17 28l8 8 14-16" stroke="var(--fp-success)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    <% } else { %>
      <svg aria-hidden="true" focusable="false" width="56" height="56" viewBox="0 0 56 56" fill="none" style="margin:0 auto;">
        <circle cx="28" cy="28" r="26" stroke="var(--fp-error)" stroke-width="3" fill="var(--fp-error-tint)"/>
        <path d="M20 20l16 16M36 20l-16 16" stroke="var(--fp-error)" stroke-width="3.5" stroke-linecap="round" fill="none"/>
      </svg>
    <% } %>
  </div>

  <!-- Title — receives focus on load -->
  <h1
    class="feedback__title"
    tabindex="-1"
    data-autofocus
    style="text-align:center; margin-bottom:var(--fp-space-2);"
  >
    <%= isCorrect ? 'Correct!' : 'Not Quite There' %>
  </h1>

  <p style="text-align:center; color:var(--fp-text-2); max-width:none; margin-bottom:var(--fp-space-2);">
    <% if (isCorrect) { %>
      Great job! You got it right.
    <% } else { %>
      Mistakes are just part of the learning process. Let's review.
    <% } %>
  </p>

  <!-- XP earned -->
  <p style="text-align:center; font-size:var(--fp-text-sm); font-weight:600; color:var(--fp-primary); margin-bottom:var(--fp-space-6);">
    +<%= xpEarned %> XP for <%= isCorrect ? 'getting it right' : 'trying' %>
  </p>

  <!-- Answer comparison (only for incorrect) -->
  <% if (!isCorrect) { %>
    <div class="card" style="margin-bottom:var(--fp-space-5); padding:var(--fp-space-5);">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:var(--fp-space-4);">
        <!-- User's answer -->
        <div style="padding:var(--fp-space-3); border-radius:var(--fp-radius); background:var(--fp-error-tint);">
          <p style="font-size:var(--fp-text-xs); font-weight:600; color:var(--fp-error); margin-bottom:var(--fp-space-1); display:flex; align-items:center; gap:var(--fp-space-1);">
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M4 4l6 6M10 4l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Your answer
          </p>
          <p style="font-size:var(--fp-text-sm); color:var(--fp-error); margin:0;">
            <s><%= userAnswer %></s>
            <span class="sr-only"> (incorrect)</span>
          </p>
        </div>
        <!-- Correct answer -->
        <div style="padding:var(--fp-space-3); border-radius:var(--fp-radius); background:var(--fp-success-tint);">
          <p style="font-size:var(--fp-text-xs); font-weight:600; color:var(--fp-success); margin-bottom:var(--fp-space-1); display:flex; align-items:center; gap:var(--fp-space-1);">
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3 7l3 3 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Correct answer
          </p>
          <p style="font-size:var(--fp-text-sm); color:var(--fp-success); font-weight:500; margin:0;"><%= correctAnswer.split('|')[0] %></p>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Pro-Tip -->
  <% if (proTip) { %>
    <div class="pro-tip" style="margin-bottom:var(--fp-space-5);">
      <p class="pro-tip__label">Pro-Tip</p>
      <p style="margin:0; max-width:none;"><%= proTip %></p>
    </div>
  <% } %>

  <!-- Stats row -->
  <div class="card" style="padding:var(--fp-space-4); margin-bottom:var(--fp-space-6);">
    <div style="display:flex; justify-content:space-around; text-align:center;">
      <div>
        <p style="font-size:var(--fp-text-lg); font-weight:700; margin-bottom:2px;"><%= userStats ? userStats.current_streak : 0 %></p>
        <p style="font-size:var(--fp-text-xs); color:var(--fp-text-2); margin:0; text-transform:uppercase; letter-spacing:0.05em;">Day streak</p>
      </div>
      <div style="border-left:1px solid var(--fp-border-card); padding-left:var(--fp-space-4);">
        <p style="font-size:var(--fp-text-lg); font-weight:700; color:var(--fp-primary); margin-bottom:2px;">+<%= xpEarned %></p>
        <p style="font-size:var(--fp-text-xs); color:var(--fp-text-2); margin:0; text-transform:uppercase; letter-spacing:0.05em;">Points</p>
      </div>
      <div style="border-left:1px solid var(--fp-border-card); padding-left:var(--fp-space-4);">
        <p style="font-size:var(--fp-text-lg); font-weight:700; margin-bottom:2px;"><%= userStats ? userStats.total_xp : 0 %></p>
        <p style="font-size:var(--fp-text-xs); color:var(--fp-text-2); margin:0; text-transform:uppercase; letter-spacing:0.05em;">Total XP</p>
      </div>
    </div>
  </div>

  <!-- Action buttons -->
  <div style="display:flex; justify-content:center; gap:var(--fp-space-3); flex-wrap:wrap;">
    <% if (!isCorrect && exercise) { %>
      <a href="/exercises/<%= exercise.id %>" class="btn btn-secondary">Try again</a>
    <% } %>

    <% if (typeof comprehensionIds !== 'undefined' && comprehensionIds.length > 0) { %>
      <!-- Reading exercise with comprehension questions -->
      <a href="/exercises/<%= comprehensionIds[0] %>" class="btn btn-primary">Test your comprehension</a>
    <% } else if (nextExerciseId) { %>
      <a href="/exercises/<%= nextExerciseId %>" class="btn btn-primary">Continue lesson</a>
    <% } else if (lesson) { %>
      <a href="/lessons/<%= lesson.id %>" class="btn btn-primary">Back to lesson</a>
    <% } else { %>
      <a href="/dashboard" class="btn btn-primary">Back to dashboard</a>
    <% } %>
  </div>

</div>
