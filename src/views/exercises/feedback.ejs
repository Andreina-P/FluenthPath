<!--
  Exercise feedback — FULL PAGE, not a modal.
  WCAG 2.1.2: No focus trap — it's a real page with its own URL.
  WCAG 2.4.2: Own <title> ("Correct!" or "Not Quite There").
  WCAG 4.1.3: NVDA reads the page title on load automatically.
  WCAG 1.4.1: Correct/incorrect shown with icon + text, not color alone.
  Focus moves to the h2 via data-autofocus (handled by focus-manager.js).
-->

<div class="feedback <%= isCorrect ? 'feedback--correct' : 'feedback--error' %>">

  <!--
    tabindex="-1" + data-autofocus: focus-manager.js moves focus here on load.
    Screen reader announces this heading immediately.
  -->
  <h2
    class="feedback__title"
    tabindex="-1"
    data-autofocus
  >
    <% if (isCorrect) { %>
      <!-- Icon + text — WCAG 1.4.1 -->
      <span aria-hidden="true" style="font-size:var(--fp-text-3xl);">&#10003;</span>
      Correct!
    <% } else { %>
      <span aria-hidden="true" style="font-size:var(--fp-text-3xl);">&#10007;</span>
      Not Quite There
    <% } %>
  </h2>

  <p style="color:var(--fp-text-2); max-width:none;">
    <% if (isCorrect) { %>
      Great job! You got it right.
    <% } else { %>
      Mistakes are just part of the learning process. Let's review.
    <% } %>
  </p>

  <!-- XP earned -->
  <p style="font-size:var(--fp-text-sm); font-weight:600; color:var(--fp-primary);">
    +<%= xpEarned %> XP for <%= isCorrect ? 'getting it right' : 'trying' %>
  </p>

  <!-- Answer comparison (only for incorrect answers) -->
  <% if (!isCorrect) { %>
    <div class="feedback-comparison">
      <!-- User's answer -->
      <div class="feedback-answer feedback-answer--user">
        <p class="feedback-answer__label">
          <span aria-hidden="true">&#10007;</span> Your answer
        </p>
        <p class="feedback-answer__text"><%= userAnswer %></p>
      </div>
      <!-- Correct answer -->
      <div class="feedback-answer feedback-answer--correct">
        <p class="feedback-answer__label">
          <span aria-hidden="true">&#10003;</span> Correct answer
        </p>
        <p class="feedback-answer__text"><%= correctAnswer %></p>
      </div>
    </div>
  <% } %>

  <!-- Pro-Tip — WCAG 3.3.3: explains the error and how to fix it -->
  <% if (proTip) { %>
    <div class="pro-tip">
      <p class="pro-tip__label">Pro-Tip</p>
      <p style="margin:0;"><%= proTip %></p>
    </div>
  <% } %>

  <!-- Stats row -->
  <div class="feedback-stats">
    <div class="feedback-stat">
      <p class="feedback-stat__value"><%= userStats ? userStats.current_streak : 0 %></p>
      <p class="feedback-stat__label">Day streak</p>
    </div>
    <div class="feedback-stat">
      <p class="feedback-stat__value">+<%= xpEarned %></p>
      <p class="feedback-stat__label">Points</p>
    </div>
    <div class="feedback-stat">
      <p class="feedback-stat__value"><%= userStats ? userStats.total_xp : 0 %></p>
      <p class="feedback-stat__label">Total XP</p>
    </div>
  </div>

  <!-- Action buttons -->
  <div class="feedback-actions">
    <% if (!isCorrect && exercise) { %>
      <a href="/exercises/<%= exercise.id %>" class="btn btn-secondary">
        Try again
      </a>
    <% } %>

    <% if (nextExerciseId) { %>
      <a href="/exercises/<%= nextExerciseId %>" class="btn btn-primary">
        Continue lesson
      </a>
    <% } else if (lesson) { %>
      <a href="/lessons/<%= lesson.id %>" class="btn btn-primary">
        Back to lesson
      </a>
    <% } else { %>
      <a href="/dashboard" class="btn btn-primary">
        Back to dashboard
      </a>
    <% } %>
  </div>

</div>
