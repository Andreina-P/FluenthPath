<!--
  Dashboard page.
  WCAG 2.4.2: Unique title "Dashboard — FluentPath"
  WCAG 1.3.1: Landmark sections with aria-labelledby
  WCAG 4.1.2: Progress bars with role="progressbar" + aria attributes
  WCAG 1.4.1: Streak/stats use text + icon, never color alone
-->

<h1>Welcome back<% if (user) { %>, <%= user.name %><% } %></h1>
<p style="color:var(--fp-text-2); margin-bottom:var(--fp-space-6);">
  Here is your learning overview. Keep up the great work.
</p>

<!-- Stats summary row -->
<section aria-labelledby="dash-stats-heading" style="margin-bottom:var(--fp-space-8);">
  <h2 id="dash-stats-heading" class="sr-only">Your quick stats</h2>

  <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(160px, 1fr)); gap:var(--fp-space-4);">

    <!-- Current level -->
    <div class="card" style="text-align:center;">
      <p style="font-size:var(--fp-text-xs); color:var(--fp-text-2); margin-bottom:var(--fp-space-1);">Current level</p>
      <p style="font-size:var(--fp-text-2xl); font-weight:700; margin:0;">
        Level <%= userStats ? userStats.current_level : 1 %>
      </p>
      <p style="font-size:var(--fp-text-xs); color:var(--fp-text-2); margin:0;">
        <%= userStats && userStats.assessment_level ? userStats.assessment_level : 'Not assessed yet' %>
      </p>
    </div>

    <!-- Streak -->
    <div class="card" style="text-align:center;">
      <p style="font-size:var(--fp-text-xs); color:var(--fp-text-2); margin-bottom:var(--fp-space-1);">Daily streak</p>
      <p style="font-size:var(--fp-text-2xl); font-weight:700; margin:0;">
        <%= userStats ? userStats.current_streak : 0 %> Days
      </p>
    </div>

    <!-- Lessons completed -->
    <div class="card" style="text-align:center;">
      <p style="font-size:var(--fp-text-xs); color:var(--fp-text-2); margin-bottom:var(--fp-space-1);">Exercises completed</p>
      <p style="font-size:var(--fp-text-2xl); font-weight:700; margin:0;">
        <%= summary ? summary.total_completed : 0 %>
      </p>
    </div>

    <!-- Accuracy -->
    <div class="card" style="text-align:center;">
      <p style="font-size:var(--fp-text-xs); color:var(--fp-text-2); margin-bottom:var(--fp-space-1);">Accuracy</p>
      <p style="font-size:var(--fp-text-2xl); font-weight:700; margin:0;">
        <%= accuracy %>%
      </p>
    </div>

  </div>
</section>

<!-- Skill Breakdown -->
<section aria-labelledby="dash-skills-heading" style="margin-bottom:var(--fp-space-8);">
  <h2 id="dash-skills-heading">Skill Breakdown</h2>

  <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(140px, 1fr)); gap:var(--fp-space-4);">

    <% const skills = [
      { name: 'Reading',   icon: '📖', pct: typeof skillPcts !== 'undefined' ? skillPcts.reading : 0 },
      { name: 'Listening', icon: '🎧', pct: typeof skillPcts !== 'undefined' ? skillPcts.listening : 0 },
      { name: 'Speaking',  icon: '🗣', pct: typeof skillPcts !== 'undefined' ? skillPcts.speaking : 0 },
      { name: 'Writing',   icon: '✏️', pct: typeof skillPcts !== 'undefined' ? skillPcts.writing : 0 },
    ]; %>

    <% skills.forEach(skill => { %>
      <div class="skill-card">
        <div class="skill-card__header">
          <span aria-hidden="true" style="font-size:var(--fp-text-xl);"><%= skill.icon %></span>
          <span class="skill-card__name"><%= skill.name %></span>
        </div>
        <div
          role="progressbar"
          aria-valuenow="<%= skill.pct %>"
          aria-valuemin="0"
          aria-valuemax="100"
          aria-label="<%= skill.name %>: <%= skill.pct %> percent complete"
          class="progress-bar"
          style="margin-top:var(--fp-space-2);"
        >
          <div class="progress-bar__fill" style="width:<%= skill.pct %>%"></div>
        </div>
        <p style="font-size:var(--fp-text-xs); color:var(--fp-text-2); margin-top:var(--fp-space-1); margin-bottom:0;">
          <%= skill.pct %>% complete
        </p>
      </div>
    <% }) %>

  </div>
</section>

<!-- Quick links -->
<section aria-labelledby="dash-actions-heading">
  <h2 id="dash-actions-heading" class="sr-only">Quick actions</h2>
  <div style="display:flex; gap:var(--fp-space-3); flex-wrap:wrap;">
    <a href="/lessons" class="btn btn-primary">Browse lessons</a>
    <% if (!userStats || !userStats.assessment_level) { %>
      <a href="/assessment" class="btn btn-secondary">Take level assessment</a>
    <% } %>
  </div>
</section>
