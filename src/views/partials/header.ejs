<!--
  Site header partial.
  WCAG 3.2.6: Help link ("?") always in the same position on every page.
  WCAG 2.4.4: All links have descriptive text.
  WCAG 2.5.3: Visible label text matches accessible name.

  Decision: No /settings or /accessibility-settings route exists.
  Accessibility is the default behavior, not a toggle.
-->
<header class="site-header" role="banner">
  <div class="site-header__inner">

    <!-- Logo / Home link -->
    <a
      href="<%= locals.user ? '/dashboard' : '/' %>"
      class="site-logo"
      aria-label="FluentPath, go to <%= locals.user ? 'dashboard' : 'home' %>"
    >
      <svg aria-hidden="true" focusable="false" width="28" height="28" viewBox="0 0 28 28" fill="none">
        <rect width="28" height="28" rx="6" fill="#1D4ED8"/>
        <path d="M7 9h14M7 14h10M7 19h7" stroke="#fff" stroke-width="2.2" stroke-linecap="round"/>
      </svg>
      <span>FluentPath</span>
    </a>

    <% if (locals.user) { %>
      <!--
        Primary navigation — only shown when authenticated.
        aria-current="page" set on the active link for screen readers.
      -->
      <nav aria-label="Main navigation">
        <ul class="site-nav" role="list">
          <li>
            <a
              href="/dashboard"
              class="site-nav__link"
              <% if (typeof currentPage !== "undefined" && currentPage === "dashboard") { %>aria-current="page"<% } %>
            >Dashboard</a>
          </li>
          <li>
            <a
              href="/lessons"
              class="site-nav__link"
              <% if (typeof currentPage !== "undefined" && currentPage === "lessons") { %>aria-current="page"<% } %>
            >Lessons</a>
          </li>
          <li>
            <a
              href="/progress"
              class="site-nav__link"
              <% if (typeof currentPage !== "undefined" && currentPage === "progress") { %>aria-current="page"<% } %>
            >Progress</a>
          </li>
        </ul>
      </nav>
    <% } %>

    <!-- Header action buttons -->
    <div class="site-header__actions">
      <% if (locals.user) { %>
        <!--
          WCAG 3.2.6: Help link — same position on every page.
          Accessible name via aria-label since it's icon-only.
        -->
        <a
          href="/help"
          class="btn btn-ghost btn-icon"
          aria-label="Help and documentation"
          <% if (typeof currentPage !== "undefined" && currentPage === "help") { %>aria-current="page"<% } %>
        >
          <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
            <path d="M10 14v.5M10 11c0-1.5 2-1.5 2-3a2 2 0 10-4 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
        <!-- Profile link — between Help and Sign Out -->
        <a
          href="/profile"
          class="btn btn-ghost btn-icon"
          aria-label="Your profile"
          <% if (typeof currentPage !== "undefined" && currentPage === "profile") { %>aria-current="page"<% } %>
        >
          <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3 18c0-3.5 3-6 7-6s7 2.5 7 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
        <!--
          Sign Out — POST to /logout (not GET) to prevent
          accidental logout from browser prefetching.
        -->
        <form action="/logout" method="POST" style="display:inline">
          <button type="submit" class="btn btn-ghost btn-icon" aria-label="Sign out of FluentPath">
            <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M13 3h4a1 1 0 011 1v12a1 1 0 01-1 1h-4M9 14l4-4-4-4M13 10H3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>

      <% } else { %>
        <!-- Public header: Sign Up (primary) + Log In (secondary) -->
        <a href="/login" class="btn btn-secondary">Log In</a>
        <a href="/register" class="btn btn-primary">Sign Up</a>
      <% } %>

    </div>
  </div>
</header>
