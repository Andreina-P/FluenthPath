<!--
  Flash messages partial.
  WCAG 3.3.1: Errors identified in text (not color alone).
  WCAG 4.1.3: role="alert" announces immediately to screen readers.

  flash is set in setLocals.js from req.session.flash.
  Structure: { type: 'error'|'success'|'info', message: 'string' }
             OR an array of { field, message } for form validation errors.
-->
<% if (typeof flash !== 'undefined' && flash) { %>

  <% if (Array.isArray(flash)) { %>
    <!--
      Validation error list.
      role="alert" + aria-live="assertive" (implicit in alert)
      ensures screen readers announce this immediately.
      WCAG 3.3.1: each error identifies the field and describes the problem.
    -->
    <div role="alert" class="flash flash--error">
      <svg class="flash__icon" aria-hidden="true" focusable="false" viewBox="0 0 20 20" fill="none">
        <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
        <path d="M10 6v4M10 13.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <div>
        <p><strong>Please fix the following errors:</strong></p>
        <ul>
          <% flash.forEach(err => { %>
            <li><%= err.message %></li>
          <% }) %>
        </ul>
      </div>
    </div>

  <% } else if (flash.type === 'error') { %>

    <div role="alert" class="flash flash--error">
      <svg class="flash__icon" aria-hidden="true" focusable="false" viewBox="0 0 20 20" fill="none">
        <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
        <path d="M10 6v4M10 13.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <p><%= flash.message %></p>
    </div>

  <% } else if (flash.type === 'success') { %>

    <!--
      Success messages use role="status" (polite) rather than role="alert"
      because they're not urgent — announced after the user finishes current action.
    -->
    <div role="status" class="flash flash--success">
      <svg class="flash__icon" aria-hidden="true" focusable="false" viewBox="0 0 20 20" fill="none">
        <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
        <path d="M6.5 10l2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p><%= flash.message %></p>
    </div>

  <% } else { %>

    <div role="status" class="flash flash--info">
      <svg class="flash__icon" aria-hidden="true" focusable="false" viewBox="0 0 20 20" fill="none">
        <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
        <path d="M10 9v5M10 6.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <p><%= flash.message %></p>
    </div>

  <% } %>

<% } %>
