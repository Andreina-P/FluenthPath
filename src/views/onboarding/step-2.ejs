<!--
  Onboarding step 2: Types of exercises.
-->

<div class="card" style="width:100%; text-align:center;">

  <div
    role="progressbar"
    aria-valuenow="2"
    aria-valuemin="1"
    aria-valuemax="3"
    aria-label="Step 2 of 3"
    style="margin-bottom:var(--fp-space-5);"
  >
    <p style="font-size:var(--fp-text-xs); color:var(--fp-text-2); margin-bottom:var(--fp-space-2);">2 / 3</p>
    <div class="progress-bar" style="max-width:200px; margin:0 auto;">
      <div class="progress-bar__fill" style="width:66%"></div>
    </div>
  </div>

  <h1 style="color:var(--fp-primary); margin-bottom:var(--fp-space-3);">Types of Exercises</h1>
  <p style="color:var(--fp-text-2); margin-bottom:var(--fp-space-6);">
    Practice with varied activities designed for rapid retention.
  </p>

  <div class="card" style="background:var(--fp-bg); text-align:left; margin-bottom:var(--fp-space-6);">
    <ul style="list-style:none; display:flex; flex-direction:column; gap:var(--fp-space-4);">
      <li style="display:flex; align-items:flex-start; gap:var(--fp-space-3);">
        <span aria-hidden="true" style="font-size:var(--fp-text-xl);">🎧</span>
        <div>
          <strong>Listening and repeat</strong>
          <p style="font-size:var(--fp-text-sm); color:var(--fp-text-2); margin:0;">Listen to audio and type or say what you hear.</p>
        </div>
      </li>
      <li style="display:flex; align-items:flex-start; gap:var(--fp-space-3);">
        <span aria-hidden="true" style="font-size:var(--fp-text-xl);">✏️</span>
        <div>
          <strong>Translate and type</strong>
          <p style="font-size:var(--fp-text-sm); color:var(--fp-text-2); margin:0;">Translate sentences into English.</p>
        </div>
      </li>
      <li style="display:flex; align-items:flex-start; gap:var(--fp-space-3);">
        <span aria-hidden="true" style="font-size:var(--fp-text-xl);">📝</span>
        <div>
          <strong>Multiple choice and word bank</strong>
          <p style="font-size:var(--fp-text-sm); color:var(--fp-text-2); margin:0;">Choose answers or build sentences from word options.</p>
        </div>
      </li>
      <li style="display:flex; align-items:flex-start; gap:var(--fp-space-3);">
        <span aria-hidden="true" style="font-size:var(--fp-text-xl);">🗣</span>
        <div>
          <strong>Speaking practice</strong>
          <p style="font-size:var(--fp-text-sm); color:var(--fp-text-2); margin:0;">Listen to a model and practice saying it out loud.</p>
        </div>
      </li>
    </ul>
  </div>

  <div style="display:flex; justify-content:center; align-items:center; gap:var(--fp-space-4);">
    <a href="/onboarding/1" class="btn btn-ghost" style="font-size:var(--fp-text-sm);">Back</a>
    <a href="/onboarding/3" class="btn btn-primary">Next</a>
    <form action="/onboarding/complete" method="POST" style="display:inline;">
      <button type="submit" class="btn btn-ghost" style="font-size:var(--fp-text-sm);">Skip</button>
    </form>
  </div>

</div>
