<!--
  Onboarding step 1: Welcome.
  Real page with its own URL — NOT a modal.
  WCAG 2.1.2: No focus trap risk.
  WCAG 2.4.2: Unique title.
-->

<div class="card" style="width:100%; text-align:center;">

  <!-- Step indicator -->
  <div
    role="progressbar"
    aria-valuenow="1"
    aria-valuemin="1"
    aria-valuemax="5"
    aria-label="Step 1 of 5"
    style="margin-bottom:var(--fp-space-5);"
  >
    <p style="font-size:var(--fp-text-xs); color:var(--fp-text-2); margin-bottom:var(--fp-space-2);">1 / 5</p>
    <div class="progress-bar" style="max-width:200px; margin:0 auto;">
      <div class="progress-bar__fill" style="width:20%"></div>
    </div>
  </div>

  <h1 style="color:var(--fp-primary); margin-bottom:var(--fp-space-3);">Welcome to FluentPath</h1>
  <p style="color:var(--fp-text-2); margin-bottom:var(--fp-space-6);">
    Practical micro-lessons to start speaking today.
  </p>

  <div class="card" style="background:var(--fp-bg); text-align:left; margin-bottom:var(--fp-space-6);">
    <ul style="list-style:none; display:flex; flex-direction:column; gap:var(--fp-space-3);">
      <li style="display:flex; align-items:flex-start; gap:var(--fp-space-3);">
        <span aria-hidden="true" style="color:var(--fp-success); font-size:var(--fp-text-lg); line-height:1;">&#10003;</span>
        <span>Quick 3 to 6 minute lessons</span>
      </li>
      <li style="display:flex; align-items:flex-start; gap:var(--fp-space-3);">
        <span aria-hidden="true" style="color:var(--fp-success); font-size:var(--fp-text-lg); line-height:1;">&#10003;</span>
        <span>Adaptive to your level</span>
      </li>
      <li style="display:flex; align-items:flex-start; gap:var(--fp-space-3);">
        <span aria-hidden="true" style="color:var(--fp-success); font-size:var(--fp-text-lg); line-height:1;">&#10003;</span>
        <span>Practical exercises to start speaking today</span>
      </li>
    </ul>
  </div>

  <div style="display:flex; justify-content:center; align-items:center; gap:var(--fp-space-6);">
    <a href="/onboarding/2" class="btn btn-primary">Next</a>
    <form action="/onboarding/complete" method="POST" style="display:inline;">
      <button type="submit" class="btn btn-ghost" style="font-size:var(--fp-text-sm);">Skip</button>
    </form>
  </div>

</div>
