<!--
  Onboarding step 4: Your learning path.
  WCAG 2.4.2: Unique title set in controller.
  WCAG 2.1.2: No focus trap — página real.
-->

<div class="card" style="width:100%; text-align:center;">

  <div
    role="progressbar"
    aria-valuenow="4"
    aria-valuemin="1"
    aria-valuemax="5"
    aria-label="Step 4 of 5"
    style="margin-bottom:var(--fp-space-5);"
  >
    <p style="font-size:var(--fp-text-xs); color:var(--fp-text-2); margin-bottom:var(--fp-space-2);">4 / 5</p>
    <div class="progress-bar" style="max-width:200px; margin:0 auto;">
      <div class="progress-bar__fill" style="width:80%"></div>
    </div>
  </div>

  <h1 style="color:var(--fp-primary); margin-bottom:var(--fp-space-3);">Your Learning Path</h1>
  <p style="color:var(--fp-text-2); margin-bottom:var(--fp-space-6);">
    Personalized path and clear progress. We adapt as you learn.
  </p>

  <div class="card" style="background:var(--fp-bg); text-align:left; margin-bottom:var(--fp-space-6);">
    <ul style="list-style:none; display:flex; flex-direction:column; gap:var(--fp-space-4);">
      <li style="display:flex; align-items:flex-start; gap:var(--fp-space-3);">
        <span aria-hidden="true" style="color:var(--fp-success); font-size:var(--fp-text-lg); line-height:1;">&#10003;</span>
        <div>
          <strong>Adaptive level assessment</strong>
          <p style="font-size:var(--fp-text-sm); color:var(--fp-text-2); margin:0;">A quick test places you at the right starting level.</p>
        </div>
      </li>
      <li style="display:flex; align-items:flex-start; gap:var(--fp-space-3);">
        <span aria-hidden="true" style="color:var(--fp-success); font-size:var(--fp-text-lg); line-height:1;">&#10003;</span>
        <div>
          <strong>Track streaks and skill bars</strong>
          <p style="font-size:var(--fp-text-sm); color:var(--fp-text-2); margin:0;">See your daily streak and progress across all skill areas.</p>
        </div>
      </li>
      <li style="display:flex; align-items:flex-start; gap:var(--fp-space-3);">
        <span aria-hidden="true" style="color:var(--fp-success); font-size:var(--fp-text-lg); line-height:1;">&#10003;</span>
        <div>
          <strong>Recommended next lesson</strong>
          <p style="font-size:var(--fp-text-sm); color:var(--fp-text-2); margin:0;">Your dashboard always shows the best next step for you.</p>
        </div>
      </li>
    </ul>
  </div>

  <div style="display:flex; justify-content:center; align-items:center; gap:var(--fp-space-4);">
    <a href="/onboarding/3" class="btn btn-ghost" style="font-size:var(--fp-text-sm);">Back</a>
    <a href="/onboarding/5" class="btn btn-primary">Next</a>
    <form action="/onboarding/complete" method="POST" style="display:inline;">
      <button type="submit" class="btn btn-ghost" style="font-size:var(--fp-text-sm);">Skip</button>
    </form>
  </div>

</div>